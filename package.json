{
  "name": "omnichannel-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nodemon --exec npx babel-node src/server.js",
    "build": "babel src -d dist",
    "start": "npx babel-node src/server.js",
    "migrate": "npx sequelize-cli db:migrate",
    "seed": "npx sequelize-cli db:seed:all",
    "migrate-and-seed": "npx sequelize-cli db:migrate && npx sequelize-cli db:seed:all"
  },
  "dependencies": {
    "@babel/cli": "^7.27.0",
    "@babel/core": "^7.27.0",
    "@babel/node": "^7.27.0",
    "@babel/preset-env": "^7.27.0",
    "axios": "^1.15.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "jwk-to-pem": "^2.0.7",
    "multer": "^2.2.0",
    "mysql2": "^3.23.1",
    "pg": "^8.13.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "sequelize-cli": "^6.6.2"
  }
}
